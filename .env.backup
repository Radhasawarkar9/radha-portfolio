# ═══════════════════════════════════════════════════════════════════
# Portfolio — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# LOCAL DEV:  cp .env.example .env  →  fill in real values  →  netlify dev
# PRODUCTION: add each key in Netlify dashboard → Site configuration
#             → Environment variables → Save → trigger redeploy
#
# ⚠  NEVER commit .env — it is listed in .gitignore
# ═══════════════════════════════════════════════════════════════════

# Supabase → Project Settings → API → "Project URL"
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase → Project Settings → API → service_role key  (server-side ONLY)
# This key bypasses RLS. Do NOT prefix with VITE_ — never sent to browser.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# Google Apps Script web-app URL (see google-apps-script/email-notifier.js)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# .env (in project root)
SUPABASE_URL=https://abcdefghij.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_actual_key_here
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbyE7izOQbm67QFL5quy4Gq2vq6qsfsxNkQsx6jdggsI2kFokVKn8xadH5Detnn5WhuS7g/exec